<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ρυθμίσεις Εκτυπωτή"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchTakeAway"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Λειτουργία Take Away"
        android:textSize="16sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Όνομα Συσκευής"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etDeviceName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="π.χ. Εκτυπωτής Κουζίνας"
        android:inputType="text"
        android:padding="12dp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnSaveSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💾 Αποθήκευση"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnRestartApp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 Επανεκκίνηση Εφαρμογής"
        android:backgroundTint="#607D8B"/>
</LinearLayout>