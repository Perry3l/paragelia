<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvHistoryType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Τύπος"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvHistoryTable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Τραπέζι: "
            android:layout_marginTop="4dp"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvHistoryAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ποσό: €0.00"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvHistoryDevice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Συσκευή: "
            android:textSize="12sp"
            android:textColor="#666" />

        <TextView
            android:id="@+id/tvHistoryTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ώρα: "
            android:textSize="12sp"
            android:textColor="#666" />

        <TextView
            android:id="@+id/tvHistoryDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Λεπτομέρειες: "
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="#888" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>